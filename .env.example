# VibeMatch Environment Variables
# Copy this file to .env and fill in the values

# MongoDB — Atlas connection string (required for production/Vercel)
# Get a free cluster at https://www.mongodb.com/atlas
MONGODB_URI="mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/vibematch?retryWrites=true&w=majority"

# Vercel Blob — token for image/video uploads (optional, falls back to base64 in dev)
# Get from Vercel project settings > Storage > Blob
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxx"

# App URL — Public URL of the app (required)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# API URL — Base URL for API calls (optional, defaults to APP_URL/api)
NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# Socket.io chat service URL (optional, needed for real-time chat)
NEXT_PUBLIC_SOCKET_URL="http://localhost:3003"
